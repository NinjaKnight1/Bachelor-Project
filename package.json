{
  "name": "bachelor-project-dbpmn-to-dpn",
  "version": "1.0.0",
  "description": "Automated Conversion of Integrated BPMN and DMN Models into Data Petri Nets",
  "scripts": {
    "all": "run-s build",
    "build": "webpack --mode production",
    "dev": "webpack-dev-server --static=public --open",
    "start": "run-s dev",
    "test": "jest --verbose",
    "test:print": "jest --verbose=false",
    "test:debug": "jest --runInBand",
    "test:watch": "jest --watch"
  },
  "keywords": [
    "bpmnjs,dmnjs,dpn"
  ],
  "license": "MIT",
  "devDependencies": {
    "@babel/preset-env": "^7.29.0",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.2.0",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.4",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-spec-reporter": "^1.0.19",
    "npm-run-all2": "^8.0.4",
    "path-intersection": "^4.1.0",
    "style-loader": "^4.0.0",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.105.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.3"
  },
  "overrides": {
    "minimatch": "^10.2.1",
    "glob": "^13.0.5",
    "test-exclude": "^7.0.1"
  },
  "dependencies": {
